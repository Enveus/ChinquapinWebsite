---
/**
 * Contact page.
 *
 * Renders the address, email, and phone from site config, plus a Web3Forms-
 * backed contact form when the access key is configured. We never collect
 * submissions ourselves — Web3Forms relays the message to the foundation's
 * inbox and redirects the visitor to /contact/thanks.
 *
 * Layout: contact methods sit on the left and the form on the right at
 * `lg` and above; below that breakpoint they stack (methods first).
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/sections/Hero.astro';
import { site } from '@config/site';

const address = site.address;
const formAccessKey = site.contactForm.accessKey;
const thanksUrl = `${site.url}/contact/thanks`;
const formAction = 'https://api.web3forms.com/submit';
const emailSubject = `New contact form submission — ${site.name}`;

const fieldClasses =
  'mt-2 w-full rounded-md border border-sage/40 bg-paper px-4 py-2.5 ' +
  'text-primary-deep placeholder:text-sage/70 ' +
  'focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30';
const labelClasses = 'block text-xs tracking-[0.3em] uppercase text-sage';
const submitClasses =
  'inline-flex items-center justify-center rounded-md bg-primary px-6 py-2.5 ' +
  'font-semibold text-paper no-underline transition-colors ' +
  'hover:bg-accent focus-visible:bg-accent';
---

<BaseLayout title="Contact" description={`Get in touch with ${site.name}.`}>
  <Hero overlayKicker="Contact" overlayHeadline="Get in touch" />

  <article class="mx-auto max-w-5xl px-6 sm:px-10 lg:px-14 py-16 sm:py-20 lg:py-24">
    <p class="font-serif text-2xl text-primary leading-snug max-w-prose">
      We'd love to hear from you — whether you want to support our work, partner with
      us, or learn more about what we do.
    </p>

    <div class="mt-12 grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)] lg:gap-16">
      <section aria-labelledby="contact-methods-heading">
        <h2 id="contact-methods-heading" class="sr-only">Contact details</h2>
        <dl class="space-y-6 text-primary-deep">
          {
            address && (
              <div>
                <dt class="text-xs tracking-[0.3em] uppercase text-sage">Mailing address</dt>
                <dd class="mt-2">
                  {address.street}
                  <br />
                  {address.city}, {address.region} {address.postalCode}
                </dd>
              </div>
            )
          }
          {
            site.contact.email && (
              <div>
                <dt class="text-xs tracking-[0.3em] uppercase text-sage">Email</dt>
                <dd class="mt-2">
                  <a class="text-accent underline underline-offset-2" href={`mailto:${site.contact.email}`}>
                    {site.contact.email}
                  </a>
                </dd>
              </div>
            )
          }
          {
            site.contact.phone && (
              <div>
                <dt class="text-xs tracking-[0.3em] uppercase text-sage">Phone</dt>
                <dd class="mt-2">
                  <a class="text-accent underline underline-offset-2" href={`tel:${site.contact.phone}`}>
                    {site.contact.phone}
                  </a>
                </dd>
              </div>
            )
          }
        </dl>

        {
          !formAccessKey && (
            <p class="mt-10 text-sm text-sage italic">
              An online contact form is coming soon. In the meantime, please reach us by email or phone.
            </p>
          )
        }
      </section>

      {
        formAccessKey && (
          <section aria-labelledby="contact-form-heading">
            <h2 id="contact-form-heading" class="font-serif text-3xl text-primary">
              Send us a message
            </h2>
            <p class="mt-3 text-primary-deep">
              Fill out the form and we'll be in touch. Required fields are marked with an asterisk.
            </p>

            <form action={formAction} method="POST" class="mt-8 space-y-6">
              <input type="hidden" name="access_key" value={formAccessKey} />
              <input type="hidden" name="subject" value={emailSubject} />
              <input type="hidden" name="from_name" value={site.name} />
              <input type="hidden" name="redirect" value={thanksUrl} />

              {/* Honeypot — bots fill hidden checkboxes; Web3Forms drops those. */}
              <input
                type="checkbox"
                name="botcheck"
                tabindex="-1"
                autocomplete="off"
                class="hidden"
                aria-hidden="true"
              />

              <div>
                <label for="contact-name" class={labelClasses}>Name <span aria-hidden="true">*</span></label>
                <input
                  id="contact-name"
                  type="text"
                  name="name"
                  autocomplete="name"
                  required
                  class={fieldClasses}
                />
              </div>

              <div>
                <label for="contact-email" class={labelClasses}>Email <span aria-hidden="true">*</span></label>
                <input
                  id="contact-email"
                  type="email"
                  name="email"
                  autocomplete="email"
                  required
                  class={fieldClasses}
                />
              </div>

              <div>
                <label for="contact-phone" class={labelClasses}>Phone <span class="lowercase tracking-normal text-sage/80">(optional)</span></label>
                <input
                  id="contact-phone"
                  type="tel"
                  name="phone"
                  autocomplete="tel"
                  class={fieldClasses}
                />
              </div>

              <div>
                <label for="contact-message" class={labelClasses}>Message <span aria-hidden="true">*</span></label>
                <textarea
                  id="contact-message"
                  name="message"
                  rows="6"
                  required
                  class={fieldClasses}
                ></textarea>
              </div>

              <button type="submit" class={submitClasses}>Send message</button>
            </form>
          </section>
        )
      }
    </div>
  </article>
</BaseLayout>
