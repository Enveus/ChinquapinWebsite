---
/**
 * Home page.
 *
 * Hero photo → welcome panel with tree-silhouette backdrop + mission + CTAs
 * → audiences cards. Tightened spacing throughout so the page sits closer
 * to one screen on desktop while still scrolling cleanly on mobile.
 *
 * Copy is anchored in the cert's stated purposes (vulnerable populations in
 * East Texas: women, children, veterans); specifics are TODO until the
 * owner supplies program details.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/sections/Hero.astro';
import WelcomeSection from '@components/sections/WelcomeSection.astro';
import { site } from '@config/site';

interface Audience {
  title: string;
  blurb: string;
  href: string;
}

const audiences: readonly Audience[] = [
  {
    title: 'Women',
    blurb:
      'Practical resources, mentorship, and faith-rooted community for women navigating hard seasons.',
    href: '/programs#women',
  },
  {
    title: 'Children',
    blurb:
      'Educational support and family-strengthening efforts that give children a stable foundation.',
    href: '/programs#children',
  },
  {
    title: 'Veterans',
    blurb:
      'Connection, resources, and dignified support for those who have served and for their families.',
    href: '/programs#veterans',
  },
] as const;
---

<BaseLayout description={site.tagline}>
  <Hero />

  <WelcomeSection kicker="Welcome to" heading={site.name}>
    <p>{site.mission}</p>
  </WelcomeSection>

  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-6 sm:px-10 lg:px-14 py-10 sm:py-12 lg:py-14">
      <div class="text-center">
        <p class="font-serif italic text-sage text-base">Who we serve</p>
        <h2 class="mt-1 font-serif text-3xl sm:text-4xl text-primary">
          Three audiences. <span class="italic text-accent">One mission.</span>
        </h2>
        <span class="mt-3 inline-block h-1 w-12 bg-sunflower rounded-full" aria-hidden="true"></span>
      </div>

      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          audiences.map((audience) => (
            <a
              href={audience.href}
              class="group block rounded-xl border border-sage/30 bg-paper p-5 no-underline transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 hover:border-accent/60"
            >
              <h3 class="font-serif text-2xl text-primary group-hover:text-accent transition-colors">
                {audience.title}
              </h3>
              <span class="mt-2 block h-0.5 w-8 bg-sunflower rounded-full" aria-hidden="true"></span>
              <p class="mt-3 text-ink text-sm leading-relaxed">
                {audience.blurb}
              </p>
              <p class="mt-3 text-accent text-sm font-semibold tracking-wide">
                Learn more <span aria-hidden="true">&rarr;</span>
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
