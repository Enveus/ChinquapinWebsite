---
/**
 * Decorative horizon band — full-width chinquapin tree silhouettes on a
 * soft olive sky. Used as a visual interlude between sections (e.g. between
 * the dark welcome panel and the lighter audiences section on the home page).
 *
 * Source artwork lives at src/assets/tree-silhouette.png and is processed
 * through Astro's Image pipeline so the build emits a responsive WebP
 * srcset instead of shipping the full 1.2 MB original.
 *
 * Purely decorative — aria-hidden so screen readers skip it.
 */

import { Image } from 'astro:assets';
import silhouette from '@assets/tree-silhouette.png';

interface Props {
  /** Extra Tailwind classes for the wrapper (e.g. spacing overrides). */
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class={`block w-full ${className}`} aria-hidden="true">
  <Image
    src={silhouette}
    alt=""
    widths={[640, 960, 1280, 1600, 2000]}
    sizes="(min-width: 1024px) calc(100vw - 280px), 100vw"
    class="block w-full h-auto"
  />
</div>
