---
/**
 * Site footer.
 *
 * The owner-supplied tree silhouette artwork sits behind the footer on every
 * page, anchored to the bottom so the dark ground line meets the bottom of
 * the viewport. A flat dark tint over the artwork keeps the address, contact,
 * and disclosure text legible while the silhouettes remain visible.
 *
 * Renders the org name, optional address/contact (omitted when unknown),
 * the 501(c)(3) disclosure with EIN (omitted when unknown), and a small
 * copyright line. We deliberately render less rather than render fake.
 */

import { Image } from 'astro:assets';
import silhouette from '@assets/tree-silhouette.png';
import { site } from '@config/site';

const year = new Date().getFullYear();
const address = site.address;
---

<footer class="relative overflow-hidden bg-primary-deep text-paper min-h-[300px] flex flex-col">
  {/* Backdrop: silhouette artwork — object-position shows the trees mid-band
      and the dark ground at the bottom, giving the footer real visual depth. */}
  <Image
    src={silhouette}
    alt=""
    widths={[640, 960, 1280, 1600, 2000]}
    sizes="(min-width: 1024px) calc(100vw - 280px), 100vw"
    class="absolute inset-0 h-full w-full object-cover object-[center_85%]"
    loading="lazy"
  />

  {/* Two layers stacked: a flat /15 base tint so the trees keep
      detail, plus a denser top band the address/contact text sits
      against. The lower portion of the footer shows the silhouette
      almost unobstructed. */}
  <div class="absolute inset-0 bg-primary-deep/15" aria-hidden="true"></div>
  <div
    class="absolute inset-x-0 top-0 h-[60%] bg-gradient-to-b from-primary-deep/80 to-primary-deep/0"
    aria-hidden="true"
  ></div>

  {/* Content sits on top of the backdrop */}
  <div class="relative flex-1 flex flex-col">
    <div class="mx-auto w-full max-w-6xl px-6 sm:px-10 lg:px-14 py-8 grid gap-6 sm:grid-cols-2 flex-1">
      <div>
        <p class="font-serif text-2xl text-paper">{site.name}</p>
        <p class="mt-3 max-w-prose text-sm text-cream">{site.tagline}</p>
      </div>

      <div class="text-sm text-cream space-y-3">
        {
          address && (
            <p>
              {address.street}
              <br />
              {address.city}, {address.region} {address.postalCode}
            </p>
          )
        }
        {
          site.contact.email && (
            <p>
              <a class="text-water underline underline-offset-2" href={`mailto:${site.contact.email}`}>
                {site.contact.email}
              </a>
            </p>
          )
        }
        {
          site.contact.phone && (
            <p>
              <a class="text-water underline underline-offset-2" href={`tel:${site.contact.phone}`}>
                {site.contact.phone}
              </a>
            </p>
          )
        }
      </div>
    </div>

    <div class="border-t border-paper/15">
      <div class="mx-auto max-w-6xl px-6 sm:px-10 lg:px-14 py-4 text-xs text-cream flex flex-col sm:flex-row sm:justify-between gap-2">
        <p>&copy; {year} {site.legalName}.</p>
        <p>
          {
            site.taxExempt501c3 && site.ein
              ? `A 501(c)(3) nonprofit · EIN ${site.ein}`
              : site.ein
                ? `Texas nonprofit corporation · EIN ${site.ein} · Federal 501(c)(3) status pending`
                : 'Texas nonprofit corporation · Federal 501(c)(3) status pending'
          }
        </p>
      </div>
    </div>
  </div>
</footer>
