---
/**
 * Inline SVG hero illustration — East Texas pond scene.
 *
 * Stylized in the brand palette: distant cabin nestled in hills, a foreground
 * chinquapin tree, yellow wildflowers, and a still pond reflecting the sky.
 *
 * TODO(owner): when you have a real photograph (e.g. of an actual ridge or
 * a service site), swap this component out for a <picture> element pointing
 * to public/hero.jpg + a WebP variant. Keep the same outer aspect ratio so
 * the layout doesn't shift.
 */
---

<svg
  viewBox="0 0 1600 720"
  preserveAspectRatio="xMidYMid slice"
  xmlns="http://www.w3.org/2000/svg"
  class="block h-full w-full"
  role="img"
  aria-label="Illustration of a still East Texas pond with a small cabin in the distance, chinquapin trees, and yellow wildflowers in the foreground."
>
  <defs>
    <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#cfe1e8" />
      <stop offset="100%" stop-color="#f2eed8" />
    </linearGradient>
    <linearGradient id="water" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#9ec1cf" />
      <stop offset="100%" stop-color="#6f96a6" />
    </linearGradient>
    <linearGradient id="hill-far" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#a8bda1" />
      <stop offset="100%" stop-color="#8aa581" />
    </linearGradient>
    <linearGradient id="hill-mid" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#7a9568" />
      <stop offset="100%" stop-color="#58754b" />
    </linearGradient>
    <linearGradient id="grass" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#58754b" />
      <stop offset="100%" stop-color="#3e4d28" />
    </linearGradient>
  </defs>

  {/* Sky */}
  <rect x="0" y="0" width="1600" height="440" fill="url(#sky)" />

  {/* Soft sun glow, upper right */}
  <circle cx="1240" cy="170" r="120" fill="#f3f4c1" opacity="0.55" />
  <circle cx="1240" cy="170" r="60" fill="#fac81c" opacity="0.35" />

  {/* Far hill range */}
  <path
    fill="url(#hill-far)"
    d="M0,420 C160,370 320,400 480,390 C660,378 820,360 980,380 C1180,406 1340,388 1600,400 L1600,470 L0,470 Z"
  />

  {/* Mid hill range with distant tree silhouettes */}
  <path
    fill="url(#hill-mid)"
    d="M0,460 C180,440 360,470 560,460 C760,450 940,420 1120,440 C1300,460 1460,450 1600,455 L1600,510 L0,510 Z"
  />

  {/* Distant cabin nestled on the far shore */}
  <g transform="translate(540 446)">
    <rect x="0" y="6" width="44" height="22" fill="#3a2a1c" />
    <polygon points="-4,6 22,-8 48,6" fill="#2a1f15" />
    <rect x="14" y="12" width="6" height="8" fill="#f3f4c1" opacity="0.85" />
    <rect x="28" y="12" width="6" height="8" fill="#f3f4c1" opacity="0.85" />
  </g>

  {/* Tiny distant trees flanking the cabin */}
  <g fill="#425031">
    <ellipse cx="500" cy="450" rx="14" ry="18" />
    <ellipse cx="612" cy="450" rx="12" ry="16" />
    <ellipse cx="640" cy="452" rx="10" ry="14" />
    <ellipse cx="470" cy="454" rx="9" ry="13" />
  </g>

  {/* Pond water */}
  <rect x="0" y="490" width="1600" height="170" fill="url(#water)" />

  {/* Water reflection of distant hills (lighter, softer) */}
  <path
    fill="#7a9568"
    opacity="0.35"
    d="M0,494 C180,506 360,498 560,504 C760,510 940,498 1120,506 C1300,514 1460,506 1600,510 L1600,524 L0,524 Z"
  />

  {/* Reflection ripples — thin horizontal strokes */}
  <g stroke="#cfe1e8" stroke-linecap="round" opacity="0.55">
    <line x1="180" y1="550" x2="320" y2="550" stroke-width="2" />
    <line x1="420" y1="572" x2="560" y2="572" stroke-width="2" />
    <line x1="720" y1="560" x2="900" y2="560" stroke-width="2" />
    <line x1="1040" y1="588" x2="1180" y2="588" stroke-width="2" />
    <line x1="1260" y1="552" x2="1380" y2="552" stroke-width="2" />
    <line x1="100" y1="610" x2="240" y2="610" stroke-width="1.5" />
    <line x1="540" y1="624" x2="700" y2="624" stroke-width="1.5" />
    <line x1="980" y1="616" x2="1140" y2="616" stroke-width="1.5" />
  </g>

  {/* Foreground shore strip */}
  <path
    fill="url(#grass)"
    d="M0,650 C220,640 440,656 680,650 C920,644 1160,656 1400,648 C1480,646 1540,650 1600,648 L1600,720 L0,720 Z"
  />

  {/* Reeds / grass blades at water's edge */}
  <g stroke="#3e4d28" stroke-linecap="round" stroke-width="2" fill="none">
    <line x1="180" y1="660" x2="178" y2="640" />
    <line x1="192" y1="662" x2="196" y2="638" />
    <line x1="206" y1="660" x2="208" y2="642" />
    <line x1="980" y1="660" x2="978" y2="638" />
    <line x1="996" y1="662" x2="1000" y2="640" />
    <line x1="1010" y1="660" x2="1008" y2="642" />
    <line x1="1024" y1="664" x2="1028" y2="640" />
  </g>

  {/* Foreground chinquapin tree — trunk + rounded foliage layers */}
  <g transform="translate(170 280)">
    <path d="M120,360 C118,300 116,240 122,170 C124,140 130,110 138,90 L150,90 C158,120 160,160 158,200 C156,260 152,320 152,360 Z" fill="#425031" />
    <path d="M150,140 C170,144 184,130 196,118" stroke="#425031" stroke-width="6" fill="none" stroke-linecap="round" />
    <path d="M122,160 C100,162 84,150 70,138" stroke="#425031" stroke-width="6" fill="none" stroke-linecap="round" />
    <ellipse cx="138" cy="80" rx="120" ry="90" fill="#58754b" />
    <ellipse cx="80" cy="110" rx="70" ry="60" fill="#3e4d28" />
    <ellipse cx="200" cy="110" rx="80" ry="60" fill="#3e4d28" />
    <ellipse cx="138" cy="60" rx="90" ry="70" fill="#425031" />
    <ellipse cx="180" cy="40" rx="60" ry="50" fill="#58754b" />
  </g>

  {/* Wildflower cluster, foreground right */}
  <g transform="translate(1180 590)">
    {/* Stems */}
    <g stroke="#3e4d28" stroke-width="3" stroke-linecap="round" fill="none">
      <line x1="20" y1="80" x2="22" y2="40" />
      <line x1="60" y1="80" x2="58" y2="32" />
      <line x1="100" y1="80" x2="104" y2="44" />
      <line x1="140" y1="80" x2="138" y2="36" />
      <line x1="180" y1="80" x2="184" y2="50" />
    </g>
    {/* Flowers — six petals each, sunflower yellow */}
    <g fill="#fac81c">
      <g transform="translate(22 30)">
        <ellipse cx="0" cy="-8" rx="6" ry="9" />
        <ellipse cx="7" cy="-3" rx="6" ry="9" transform="rotate(60)" />
        <ellipse cx="7" cy="3" rx="6" ry="9" transform="rotate(120)" />
        <ellipse cx="0" cy="8" rx="6" ry="9" />
        <ellipse cx="-7" cy="3" rx="6" ry="9" transform="rotate(240)" />
        <ellipse cx="-7" cy="-3" rx="6" ry="9" transform="rotate(300)" />
        <circle cx="0" cy="0" r="3" fill="#3e4d28" />
      </g>
      <g transform="translate(58 22)">
        <ellipse cx="0" cy="-9" rx="7" ry="10" />
        <ellipse cx="8" cy="-3" rx="7" ry="10" transform="rotate(60)" />
        <ellipse cx="8" cy="3" rx="7" ry="10" transform="rotate(120)" />
        <ellipse cx="0" cy="9" rx="7" ry="10" />
        <ellipse cx="-8" cy="3" rx="7" ry="10" transform="rotate(240)" />
        <ellipse cx="-8" cy="-3" rx="7" ry="10" transform="rotate(300)" />
        <circle cx="0" cy="0" r="3" fill="#3e4d28" />
      </g>
      <g transform="translate(104 34)">
        <ellipse cx="0" cy="-8" rx="6" ry="9" />
        <ellipse cx="7" cy="-3" rx="6" ry="9" transform="rotate(60)" />
        <ellipse cx="7" cy="3" rx="6" ry="9" transform="rotate(120)" />
        <ellipse cx="0" cy="8" rx="6" ry="9" />
        <ellipse cx="-7" cy="3" rx="6" ry="9" transform="rotate(240)" />
        <ellipse cx="-7" cy="-3" rx="6" ry="9" transform="rotate(300)" />
        <circle cx="0" cy="0" r="3" fill="#3e4d28" />
      </g>
      <g transform="translate(138 26)">
        <ellipse cx="0" cy="-9" rx="7" ry="10" />
        <ellipse cx="8" cy="-3" rx="7" ry="10" transform="rotate(60)" />
        <ellipse cx="8" cy="3" rx="7" ry="10" transform="rotate(120)" />
        <ellipse cx="0" cy="9" rx="7" ry="10" />
        <ellipse cx="-8" cy="3" rx="7" ry="10" transform="rotate(240)" />
        <ellipse cx="-8" cy="-3" rx="7" ry="10" transform="rotate(300)" />
        <circle cx="0" cy="0" r="3" fill="#3e4d28" />
      </g>
      <g transform="translate(184 38)">
        <ellipse cx="0" cy="-7" rx="5" ry="8" />
        <ellipse cx="6" cy="-2" rx="5" ry="8" transform="rotate(60)" />
        <ellipse cx="6" cy="2" rx="5" ry="8" transform="rotate(120)" />
        <ellipse cx="0" cy="7" rx="5" ry="8" />
        <ellipse cx="-6" cy="2" rx="5" ry="8" transform="rotate(240)" />
        <ellipse cx="-6" cy="-2" rx="5" ry="8" transform="rotate(300)" />
        <circle cx="0" cy="0" r="2.5" fill="#3e4d28" />
      </g>
    </g>
    {/* Leaves at base */}
    <g fill="#58754b">
      <ellipse cx="20" cy="80" rx="14" ry="6" />
      <ellipse cx="60" cy="80" rx="14" ry="6" />
      <ellipse cx="100" cy="80" rx="14" ry="6" />
      <ellipse cx="140" cy="80" rx="14" ry="6" />
      <ellipse cx="180" cy="80" rx="14" ry="6" />
    </g>
  </g>
</svg>
