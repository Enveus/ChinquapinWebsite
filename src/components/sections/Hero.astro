---
/**
 * Home hero — the large photographic banner at the top of the page.
 *
 * Source photo lives at src/assets/hero.png and is processed through Astro's
 * Image pipeline: it ships as a responsive WebP with srcset entries for
 * common viewport widths. That drops the 3+ MB original to a few hundred KB
 * for typical visitors.
 *
 * Aspect ratio steps from 4:3 on mobile (close to the native photo aspect)
 * to 16:9 on tablet+ so the foreground daffodils and the cabin both stay in
 * frame. Object-position is biased slightly below center so the daffodils
 * don't get cropped off the bottom.
 *
 * The optional `overlayKicker` and `overlayHeadline` render as a subtle
 * caption at the bottom-left of the hero — handy on inner pages. A soft
 * gradient under the overlay keeps the text legible against bright sky.
 */

import { Image } from 'astro:assets';
import heroPhoto from '@assets/hero.png';

interface Props {
  overlayKicker?: string;
  overlayHeadline?: string;
}

const { overlayKicker, overlayHeadline } = Astro.props;
const hasOverlay = Boolean(overlayKicker || overlayHeadline);
---

<section
  class="relative w-full overflow-hidden h-[55vh] sm:h-[60vh] lg:h-[68vh] max-h-[680px] min-h-[320px]"
  aria-label="Hero"
>
  <Image
    src={heroPhoto}
    alt="A still pond reflecting trees and blue sky, with a wooden cabin nestled on the far shore and yellow daffodils in the foreground."
    class="absolute inset-0 h-full w-full object-cover object-[center_60%]"
    widths={[640, 960, 1280, 1600]}
    sizes="(min-width: 1024px) calc(100vw - 280px), 100vw"
    loading="eager"
    fetchpriority="high"
  />

  {
    hasOverlay && (
      <>
        <div class="pointer-events-none absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-primary-deep/85 via-primary-deep/50 to-transparent" />
        <div class="absolute inset-x-0 bottom-0 p-6 sm:p-10 lg:p-14">
          <div class="max-w-3xl">
            {overlayKicker && (
              <p class="font-serif italic text-water text-lg sm:text-xl drop-shadow">
                {overlayKicker}
              </p>
            )}
            {overlayHeadline && (
              <h1 class="mt-2 font-serif text-4xl sm:text-5xl lg:text-6xl text-paper drop-shadow-md leading-[1.05]">
                {overlayHeadline}
              </h1>
            )}
            {overlayHeadline && (
              <span class="mt-5 block h-1 w-16 bg-sunflower rounded-full" aria-hidden="true"></span>
            )}
          </div>
        </div>
      </>
    )
  }
</section>
