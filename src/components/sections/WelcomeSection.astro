---
/**
 * Welcome section — the dark green panel that sits directly below the hero
 * on the home page. Two-column on desktop (heading left, paragraph right),
 * stacked on mobile. A short sunflower-yellow rule sits beneath the heading
 * as a brand accent. The decorative tree silhouette band caps the bottom.
 *
 * Body copy and CTAs use solid colors (not opacity modifiers) so contrast
 * stays predictable on the dark green background.
 */

import DonateButton from '@components/ui/DonateButton.astro';

interface Props {
  kicker?: string;
  heading: string;
  /** Secondary CTA label & href. Defaults to "Learn more" → /about. */
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  kicker,
  heading,
  secondaryLabel = 'Learn more',
  secondaryHref = '/about',
} = Astro.props;
---

<section class="bg-primary-deep text-paper">
  <div class="mx-auto max-w-6xl px-6 sm:px-10 lg:px-14 py-16 sm:py-20 lg:py-24">
    <div class="grid gap-10 lg:grid-cols-[5fr_6fr] lg:gap-20">
      <div>
        {kicker && (
          <p class="font-serif italic text-water text-lg sm:text-xl">{kicker}</p>
        )}
        <h2 class="mt-2 font-serif text-4xl sm:text-5xl lg:text-6xl leading-[1.05] text-paper">
          {heading}
        </h2>
        <span class="mt-6 block h-1 w-16 bg-sunflower rounded-full" aria-hidden="true"></span>
      </div>

      <div class="text-cream space-y-5 text-base sm:text-lg leading-relaxed">
        <slot />

        <div class="flex flex-wrap items-center gap-4 pt-3">
          <a
            href={secondaryHref}
            class="inline-flex items-center justify-center rounded-md border border-paper/70 px-5 py-2.5 font-semibold text-paper no-underline hover:bg-paper hover:text-primary-deep transition-colors"
          >
            {secondaryLabel}
          </a>
          <DonateButton />
        </div>
      </div>
    </div>
  </div>
</section>
