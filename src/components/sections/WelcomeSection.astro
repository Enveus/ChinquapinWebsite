---
/**
 * Welcome section — plain dark green panel with the mission and CTAs.
 * Two-column on desktop (heading left, paragraph right), stacked on mobile.
 * A short sunflower-yellow rule sits beneath the heading as a brand accent.
 *
 * The tree silhouette artwork now lives behind the footer (see Footer.astro)
 * so it appears on every page rather than the home page only.
 */

import DonateButton from '@components/ui/DonateButton.astro';

interface Props {
  kicker?: string;
  heading: string;
  /** Secondary CTA label & href. Defaults to "Learn more" → /about. */
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  kicker,
  heading,
  secondaryLabel = 'Learn more',
  secondaryHref = '/about',
} = Astro.props;
---

<section class="bg-primary-deep text-paper">
  <div class="mx-auto max-w-6xl px-6 sm:px-10 lg:px-14 py-12 sm:py-14 lg:py-16">
    <div class="grid gap-8 lg:grid-cols-[5fr_6fr] lg:gap-16">
      <div>
        {kicker && (
          <p class="font-serif italic text-water text-lg">{kicker}</p>
        )}
        <h2 class="mt-1 font-serif text-3xl sm:text-4xl lg:text-5xl leading-[1.05] text-paper">
          {heading}
        </h2>
        <span class="mt-4 block h-1 w-14 bg-sunflower rounded-full" aria-hidden="true"></span>
      </div>

      <div class="text-cream space-y-4 text-base leading-relaxed">
        <slot />

        <div class="flex flex-wrap items-center gap-3 pt-2">
          <a
            href={secondaryHref}
            class="inline-flex items-center justify-center rounded-md border border-paper/70 px-4 py-2 font-semibold text-paper no-underline hover:bg-paper hover:text-primary-deep transition-colors"
          >
            {secondaryLabel}
          </a>
          <DonateButton />
        </div>
      </div>
    </div>
  </div>
</section>
